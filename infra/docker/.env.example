# PostgreSQL
POSTGRES_USER=threatfusion
POSTGRES_PASSWORD=threatfusion
POSTGRES_DB=threatfusion
DATABASE_URL=postgresql://threatfusion:threatfusion@postgres:5432/threatfusion

# RabbitMQ / Celery
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=db+postgresql://threatfusion:threatfusion@postgres:5432/threatfusion

# Redis (pont temps réel Celery -> WebSocket, voir ADR 0004)
REDIS_URL=redis://redis:6379/0

# Backend
SECRET_KEY=change-me
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3001
